# App Settings
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite:///./code_analyzer.db

# File Storage
UPLOAD_DIR=./uploads
CLONE_DIR=./cloned_repos
MAX_UPLOAD_SIZE_MB=50

# AI Provider Keys (optional - can also configure via API)
OPENAI_API_KEY=
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
DASHSCOPE_API_KEY=

# Git proxy (required if behind a firewall/GFW)
GIT_PROXY=
